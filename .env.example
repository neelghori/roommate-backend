NODE_ENV=development
PORT=5000

# Production reverse proxy (nginx): set client_max_body_size 64m on api host or uploads return 413.
# See deploy/nginx-api-uploads.conf
MONGODB_URI=mongodb://127.0.0.1:27017/roommate
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=1d
# Comma-separated origins for browser CORS checks
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# Base website URL used in signup verify-email links
APP_PUBLIC_FRONTEND_URL=http://localhost:3000
BCRYPT_SALT_ROUNDS=12

# Resend (https://resend.com) ? admin forgot password + signup verification emails
RESEND_API_KEY=
# Must be a verified sender in Resend, e.g. onboarding@resend.dev or noreply@yourdomain.com
EMAIL_FROM=Roommat <onboarding@resend.dev>
# Optional: full https URL to logo image for emails. If empty, uses APP_PUBLIC_FRONTEND_URL/logo.png
EMAIL_LOGO_URL=
# Optional full URL where admin enters new password (token appended as ?token=).
# If empty, backend uses APP_PUBLIC_FRONTEND_URL + /admin/reset-password.
# Example: https://admin.roommat.com/reset-password
ADMIN_PASSWORD_RESET_BASE_URL=
# Admin panel URL for staff web push links (property review, etc.)
ADMIN_PUBLIC_FRONTEND_URL=http://localhost:3001
PASSWORD_RESET_EXPIRES_MINUTES=60
# Signup confirmation link lifetime (hours)
EMAIL_VERIFICATION_EXPIRES_HOURS=48

# Web Push (VAPID) — generate: npx web-push generate-vapid-keys
# Public key is exposed via GET /api/v1/push/vapid-public-key
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@roommat.in

# Google Sign-In (same client ID as website NEXT_PUBLIC_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Superadmin seeder: npm run seed:superadmin
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change_me_min_8_chars
SUPERADMIN_NAME=Super Admin
